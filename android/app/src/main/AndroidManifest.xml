<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Tool permissions (Phase 3-4) -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- Required for AlarmClock.ACTION_SET_TIMER / ACTION_SET_ALARM with EXTRA_SKIP_UI=true.
         Without this, the system silently ignores SKIP_UI and our "set a timer" tool call
         appears to do nothing on devices that strictly enforce the permission. -->
    <uses-permission android:name="com.android.alarm.permission.SET_ALARM" />

    <!-- launchApp tool needs to see other apps' launcher activities on Android 11+. The
         additional intent queries make play-from-search resolvable, and the explicit Metrolist
         package entry lets us check whether it's installed via getApplicationInfo. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.media.action.MEDIA_PLAY_FROM_SEARCH" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" android:host="music.youtube.com" />
        </intent>
        <package android:name="com.metrolist.music" />
        <!-- Poweramp is the preferred target for play_song: documented API, reliable
             onPlayFromSearch handler, and read-access to its content provider for direct
             artist/album lookup if we ever need it. -->
        <package android:name="com.maxmpz.audioplayer" />
    </queries>

    <application
        android:name=".VelaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@android:drawable/ic_dialog_info"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/ic_dialog_info"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vela"
        tools:targetApi="31">

        <!-- Required by LiteRT-LM docs to enable Backend.GPU(). Without these the platform
             linker won't expose libOpenCL.so to the app even when the device has it, so the
             GPU sampler crashes on init. `required="false"` keeps the app installable on
             devices that lack the libs (we fall back to Backend.CPU() at runtime). -->
        <uses-native-library android:name="libvndksupport.so" android:required="false" />
        <uses-native-library android:name="libOpenCL.so" android:required="false" />

        <!-- Qualcomm DSP-RPC vendor library — needed by libQnnHtpV*Stub.so to bridge calls
             from the CPU to the Hexagon NPU. Lives at /vendor/lib64/libcdsprpc.so on
             Snapdragon devices, but Android's namespace-isolated linker hides vendor libs
             from apps unless explicitly requested. Without this, dlopen of the Stub lib
             fails with "library libcdsprpc.so not found" and the dispatch path can't
             initialise. required="false" so the app still installs on non-Qualcomm devices. -->
        <uses-native-library android:name="libcdsprpc.so" android:required="false" />

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Vela"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Music tools (now-playing) need MediaSessionManager.getActiveSessions, which requires
             this listener to be enabled by the user under Settings → Notification access. -->
        <service
            android:name=".data.system.AssistantNotificationListener"
            android:exported="false"
            android:label="Vela notification access"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Phase 5: become the system assistant. The user grants this via
             RoleManager.ROLE_ASSISTANT; once granted, long-press home / assist gesture brings
             up our overlay session.

             VoiceInteractionService is the bind point — empty class, just a marker. The
             metadata XML points the framework at the SessionService (overlay factory) and
             the stub RecognitionService (required by the XML schema even though Gemma 4
             handles audio directly without a separate STT). -->
        <service
            android:name=".presentation.voice.VelaVoiceInteractionService"
            android:exported="true"
            android:label="Vela"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/voice_interaction_service" />
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
        </service>
        <service
            android:name=".presentation.voice.VelaVoiceInteractionSessionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION" />
        <service
            android:name=".presentation.voice.StubRecognitionService"
            android:exported="true"
            android:label="Vela speech recognition">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>
            <meta-data
                android:name="android.speech"
                android:resource="@xml/recognition_service" />
        </service>
    </application>

</manifest>
