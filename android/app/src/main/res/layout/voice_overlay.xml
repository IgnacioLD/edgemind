<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/edge_background"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="48dp"
    android:paddingBottom="48dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/voice_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vela"
        android:textColor="@color/edge_on_surface"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/voice_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/edge_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.05"
        android:layout_marginBottom="28dp" />

    <TextView
        android:id="@+id/voice_response"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/edge_on_surface"
        android:textSize="17sp"
        android:lineSpacingMultiplier="1.3"
        android:gravity="center" />

    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ImageButton
        android:id="@+id/voice_mic"
        android:layout_width="92dp"
        android:layout_height="92dp"
        android:background="@drawable/voice_mic_bg"
        android:src="@android:drawable/ic_btn_speak_now"
        android:scaleType="centerInside"
        android:tint="@color/edge_on_primary"
        android:contentDescription="Stop listening" />

    <Button
        android:id="@+id/voice_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Close"
        android:textColor="@color/edge_on_surface_variant"
        android:background="@android:color/transparent"
        android:layout_marginTop="20dp" />
</LinearLayout>
