<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Minimal Activity theme — Compose drives the actual visual style via VelaTheme.
         The background color stops the launch screen from flashing light before Compose renders. -->
    <style name="Theme.Vela" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/edge_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/edge_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
